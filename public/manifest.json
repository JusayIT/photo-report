{
    "name": "OS Photo Report PWA",
    "short_name": "OS-PWA",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#2563eb",
    "icons": [
      {
        "src": "/icon-192.png",
        "sizes": "192x192",
        "type": "image/png"
      }
    ],
    "share_target": {
      "action": "/shared-incoming-file",
      "method": "POST",
      "enctype": "multipart/form-data",
      "params": {
        "files": [
          {
            "name": "shared-file",
            "accept": ["image/*"]
          }
        ]
      }
    }
  }